{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lhrsolar.org/lhrs-mdc/3.0.0/defs/multiplexing.json",
  "$defs": {
    "multiplexing": {
      "type": "object",
      "description": "Message-level multiplexing summary. Per-signal detail lives in each signal's `is_multiplexer` / `multiplexer_signal` / `multiplexer_ids` fields.",
      "additionalProperties": false,
      "properties": {
        "multiplexed": { "type": "boolean", "description": "Whether the message uses multiplexing.", "default": false },
        "multiplexorSignal": { "type": "string", "description": "Name of the selector signal." },
        "extended": { "type": "boolean", "description": "Whether extended/nested multiplexing is used.", "default": false }
      }
    }
  }
}
