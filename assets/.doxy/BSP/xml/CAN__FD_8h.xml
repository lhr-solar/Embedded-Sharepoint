        <definition>can_status_t can_fd_recv</definition>
        <argsstring>(FDCAN_HandleTypeDef *handle, uint16_t id, FDCAN_RxHeaderTypeDef *header, uint8_t data[], TickType_t delay_ticks)</argsstring>
        <name>can_fd_recv</name>
        <param>
          <type>FDCAN_HandleTypeDef *</type>
          <declname>handle</declname>
        </param>
        <param>
          <type>uint16_t</type>
          <declname>id</declname>
        </param>
        <param>
